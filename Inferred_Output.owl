<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/yaziz/ontologies/academic-organization#"
     xml:base="http://www.semanticweb.org/yaziz/ontologies/academic-organization"
     xmlns:ao="http://www.semanticweb.org/yaziz/ontologies/academic-organization#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization">
        <owl:versionIRI rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization/2.0.0"/>
        <rdfs:comment>An ontology describing the structure of an academic organization: people (staff and students), organizational units, courses and locations. Developed by Yasir Aziz for the Knowledge Representation course.</rdfs:comment>
        <rdfs:label>Academic Organization Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#advisedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#advisedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#advises"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Professor"/>
        <rdfs:label>advisedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#advises -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#advises">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Professor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student"/>
        <rdfs:label>advises</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#enrolledIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#enrolledIn">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasStudent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course"/>
        <rdfs:label>enrolledIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasPrerequisite -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasPrerequisite">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course"/>
        <rdfs:label>hasPrerequisite</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasStudent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasStudent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student"/>
        <rdfs:label>hasStudent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#headedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#headedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Department"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Dean"/>
        <rdfs:label>headedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#isPartOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#isPartOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Organization"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Organization"/>
        <rdfs:label>isPartOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#isTaughtBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#isTaughtBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#teaches"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Professor"/>
        <rdfs:label>isTaughtBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#locatedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#locatedIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Location"/>
        <rdfs:label>locatedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#memberOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#memberOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Research_Group"/>
        <rdfs:label>memberOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#teaches -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#teaches">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Professor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course"/>
        <rdfs:label>teaches</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#worksIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#worksIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Staff"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Organization"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#worksIn"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#isPartOf"/>
        </owl:propertyChainAxiom>
        <rdfs:label>worksIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasCapacity -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasCapacity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>hasCapacity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasCredits -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasCredits">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>hasCredits</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasEmail -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasEmail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>hasEmail</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasFullName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasFullName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>hasFullName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasGPA -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasGPA">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>hasGPA</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasStudentID -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasStudentID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>hasStudentID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasYear -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasYear">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>hasYear</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Administrator -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Administrator">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Staff"/>
        <rdfs:label>Administrator</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Classroom -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Classroom">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Location"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Lab"/>
        <rdfs:label>Classroom</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>An academic course taught within the organization.</rdfs:comment>
        <rdfs:label>Course</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Dean -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Dean">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Administrator"/>
        <rdfs:label>Dean</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Department -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Department">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Organization"/>
        <rdfs:label>Department</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Faculty -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Faculty">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Organization"/>
        <rdfs:label>Faculty</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Graduate -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Graduate">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Undergraduate"/>
        <rdfs:label>Graduate</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Lab -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Lab">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Location"/>
        <rdfs:label>Lab</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Lecturer -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Lecturer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Staff"/>
        <rdfs:label>Lecturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Location -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Location">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:label>Location</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Organization -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Organization">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:label>Organization</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Person -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Person">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>Any human being within the academic organization.</rdfs:comment>
        <rdfs:label>Person</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#PhD_Student -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#PhD_Student">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Graduate"/>
        <rdfs:label>PhD_Student</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Professor -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Professor">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Staff"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#teaches"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A member of staff who teaches at least one course.</rdfs:comment>
        <rdfs:label>Professor</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Research_Group -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Research_Group">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Organization"/>
        <rdfs:label>Research_Group</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Staff -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Staff">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Person"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student"/>
        <rdfs:label>Staff</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Person"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#hasStudentID"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A person enrolled in the organization who has exactly one student ID.</rdfs:comment>
        <rdfs:label>Student</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Undergraduate -->

    <owl:Class rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Undergraduate">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Student"/>
        <rdfs:label>Undergraduate</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#AI_Research_Group -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#AI_Research_Group">
        <rdf:type rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Research_Group"/>
        <isPartOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#ComputerScience_Dept"/>
        <isPartOf rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Faculty_of_Science"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Advanced_Algorithms -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Advanced_Algorithms">
        <rdf:type rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Course"/>
        <hasPrerequisite rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Data_Structures"/>
        <hasPrerequisite rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Intro_Programming"/>
        <hasCredits rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">9</hasCredits>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Alice -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Alice">
        <rdf:type rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Undergraduate"/>
        <advisedBy rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Prof_Smith"/>
        <enrolledIn rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Intro_Programming"/>
        <hasEmail>alice@student.university.edu</hasEmail>
        <hasFullName>Alice Green</hasFullName>
        <hasGPA rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3.8</hasGPA>
        <hasStudentID rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1001</hasStudentID>
        <hasYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</hasYear>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/yaziz/ontologies/academic-organization#Bob -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Bob">
        <rdf:type rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Graduate"/>
        <advisedBy rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Prof_Jones"/>
        <enrolledIn rdf:resource="http://www.semanticweb.org/yaziz/ontologies/academic-organization#Data_Structures"/>
